# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Bible (로컬 JSON 사용 - 외부 API 불필요)

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Google OAuth (Google Cloud Console에서 발급)
# Web: OAuth 2.0 클라이언트 ID (웹 애플리케이션)
# Android: OAuth 2.0 클라이언트 ID (Android)
# iOS: OAuth 2.0 클라이언트 ID (iOS)
GOOGLE_CLIENT_ID_WEB=your_google_client_id_web_here
GOOGLE_CLIENT_ID_ANDROID=your_google_client_id_android_here
GOOGLE_CLIENT_ID_IOS=your_google_client_id_ios_here

# Firebase (Phase 5에서 사용)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

